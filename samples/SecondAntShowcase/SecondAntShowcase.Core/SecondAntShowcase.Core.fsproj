<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
  </PropertyGroup>
  <!-- Pure, testable showcase core + harness. Consumes the framework as packed packages
       only (no ProjectReference into src/ — FR-015 / SC-006). Renders ONLY under the Ant
       theme: FS.GG.UI.Themes.AntDesign is referenced; FS.GG.UI.Themes.Default is NOT.
       Compile order is the type-dependency order:
       Model -> AntTheme -> DemoState -> VisualConfig -> ShellLayout -> PageProfiles ->
       Pages -> Templates -> PageRegistry -> CoverageMap -> InteractionContracts ->
       ReviewFindings -> Scripts -> VisualReadinessWorkflow -> Shell -> Host -> Evidence. -->
  <ItemGroup>
    <Compile Include="Model.fsi" />
    <Compile Include="Model.fs" />
    <Compile Include="AntTheme.fsi" />
    <Compile Include="AntTheme.fs" />
    <Compile Include="DemoState.fsi" />
    <Compile Include="DemoState.fs" />
    <Compile Include="VisualConfig.fsi" />
    <Compile Include="VisualConfig.fs" />
    <Compile Include="ShellLayout.fsi" />
    <Compile Include="ShellLayout.fs" />
    <Compile Include="PageProfiles.fsi" />
    <Compile Include="PageProfiles.fs" />
    <Compile Include="Pages.fsi" />
    <Compile Include="Pages.fs" />
    <Compile Include="Templates.fsi" />
    <Compile Include="Templates.fs" />
    <Compile Include="PageRegistry.fsi" />
    <Compile Include="PageRegistry.fs" />
    <Compile Include="CoverageMap.fsi" />
    <Compile Include="CoverageMap.fs" />
    <Compile Include="InteractionContracts.fsi" />
    <Compile Include="InteractionContracts.fs" />
    <Compile Include="ReviewFindings.fsi" />
    <Compile Include="ReviewFindings.fs" />
    <Compile Include="Scripts.fs" />
    <Compile Include="VisualReadinessWorkflow.fsi" />
    <Compile Include="VisualReadinessWorkflow.fs" />
    <Compile Include="Shell.fsi" />
    <Compile Include="Shell.fs" />
    <Compile Include="Host.fs" />
    <Compile Include="Evidence.fsi" />
    <Compile Include="Evidence.fs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FS.GG.UI.Themes.AntDesign" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.Controls" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.Color" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.Scene" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.Controls.Elmish" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.SkiaViewer" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.Testing" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.DesignSystem" Version="0.1.32-preview.1" />
    <PackageReference Include="FS.GG.UI.KeyboardInput" Version="0.1.32-preview.1" />
  </ItemGroup>
</Project>
