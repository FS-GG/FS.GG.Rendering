<?xml version="1.0" encoding="utf-8"?>
<!-- Controls Gallery consumes the framework ONLY as packed FS.GG.UI.* NuGet packages
     (research R1 / FR-013 / SC-005). This local feed is the documented consumer path;
     building against it IS the proof that path works end to end. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget-local" value="/home/developer/.local/share/nuget-local" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget-local">
      <package pattern="FS.GG.UI.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
