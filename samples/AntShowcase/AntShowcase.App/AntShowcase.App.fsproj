<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>AntShowcase</AssemblyName>
  </PropertyGroup>

  <!-- The thin edge / interpreter: turns the pure Core into a live window or a
       headless evidence run. References Core by project, the rest as packages. -->
  <ItemGroup>
    <Compile Include="FeedbackStore.fs" />
    <Compile Include="Interactive.fs" />
    <Compile Include="Evidence.fs" />
    <Compile Include="VisualReadiness.fsi" />
    <Compile Include="VisualReadiness.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AntShowcase.Core\AntShowcase.Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FS.GG.UI.Controls.Elmish" Version="0.1.24-preview.1" />
    <PackageReference Include="FS.GG.UI.SkiaViewer" Version="0.1.24-preview.1" />
    <PackageReference Include="FS.GG.UI.Testing" Version="0.1.24-preview.1" />
    <PackageReference Include="SkiaSharp" Version="4.147.0-preview.3.1" />
  </ItemGroup>

</Project>
