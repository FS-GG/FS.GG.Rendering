<?xml version="1.0" encoding="utf-8"?>
<!-- Ant Design Controls Showcase (G3) consumes the framework ONLY as packed FS.GG.UI.*
     NuGet packages (research R1 / FR-015 / SC-006). This local feed is the documented
     consumer path; building against it IS the proof the Ant-theme consumer path works
     end to end. The feed MUST be refreshed (quickstart V0) so it carries
     FS.GG.UI.Themes.AntDesign and the 96-control FS.GG.UI.Controls. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget-local" value="/home/developer/.local/share/nuget-local" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget-local">
      <package pattern="FS.GG.UI.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
