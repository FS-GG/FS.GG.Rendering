  <ItemGroup>
    <ProjectReference Include="..\..\src\Controls\Controls.fsproj" />
    <ProjectReference Include="..\..\src\Diagnostics\Diagnostics.fsproj" />
    <!-- Feature 125: the design-system primitives and the default theme were carved out of
         Controls into their own packages; the suites exercise both (Theme.light/dark, Style.resolve,
         the relocated types), so reference them directly. -->
    <ProjectReference Include="..\..\src\DesignSystem\DesignSystem.fsproj" />
    <ProjectReference Include="..\..\src\Themes.Default\Themes.Default.fsproj" />
    <!-- Feature 132 (D2.1): the Ant Design theme package the parity + contract suites resolve. -->
    <ProjectReference Include="..\..\src\Themes.AntDesign\Themes.AntDesign.fsproj" />
    <!-- Feature 108 (US6, T032): the theming-contrast suite reuses FS.GG.UI.Color.Contrast.ratio
         against the WCAG reference pairs. Test-only reference — Controls itself does not depend on
         the ColorPolicy project (no package-graph change). Feature 179 (US3): retired src/Color;
         Contrast + the internal ColorPolicy engine relocated to the non-packed src/ColorPolicy
         (namespace + IVT preserved, so these suites are edit-free). -->
    <ProjectReference Include="..\..\src\ColorPolicy\ColorPolicy.fsproj" />
    <!-- Feature 178 (US1): the shared repository-root finder lives in the non-packed TestSupport assembly. -->
    <ProjectReference Include="..\TestSupport\TestSupport.fsproj" />
    <!-- R4 import: the Feature-066 typed-catalog drift suite (CatalogTests.fs) referenced the
         governance engine (FS.GG.UI.Build); removed per FR-006 (no governance runtime). The
         typed-catalog drift check belongs to the governance repo, not the rendering product. -->
    <PackageReference Include="Expecto" />
    <!-- Feature 067: FsCheck (test-only, pinned 3.3.3 in Directory.Packages.props)
         drives the round-trip and determinism properties for the internal
         reconciler. Not a product dependency — DependencyReport is unaffected. -->
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

</Project>
