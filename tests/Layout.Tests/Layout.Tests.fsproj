<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Feature 136 (T006): shared Scene-only assertion helpers (canonical copy in Rendering.Harness). -->
    <Compile Include="..\Rendering.Harness\TestAssertions.fs">
      <Link>TestAssertions.fs</Link>
    </Compile>
    <Compile Include="Tests.fs" />
    <Compile Include="YogaFallbackDiagnosticsTests.fs" />
    <Compile Include="Feature097IncrementalTests.fs" />
    <Compile Include="Feature138IncrementalLayoutTests.fs" />
    <Compile Include="Audit_IncrementalLayout.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Scene\Scene.fsproj" />
    <ProjectReference Include="..\..\src\Layout\Layout.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

</Project>
