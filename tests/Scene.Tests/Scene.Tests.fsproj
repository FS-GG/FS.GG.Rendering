<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Feature 136 (T006): shared Scene-only assertion helpers (canonical copy in Rendering.Harness). -->
    <Compile Include="..\Rendering.Harness\TestAssertions.fs">
      <Link>TestAssertions.fs</Link>
    </Compile>
    <Compile Include="Tests.fs" />
    <Compile Include="AnimationTests.fs" />
    <Compile Include="Audit_AnimationSampling.fs" />
    <Compile Include="Feature136MeasurementSeamTests.fs" />
    <Compile Include="Feature140GlyphRunTests.fs" />
    <Compile Include="Feature142ShapedTextTests.fs" />
    <Compile Include="Feature142RunItemizationTests.fs" />
    <Compile Include="Feature142ShapedTextDeterminismTests.fs" />
    <Compile Include="Feature142PureFallbackCompatibilityTests.fs" />
    <Compile Include="Feature146PortableSceneRoundTripTests.fs" />
    <Compile Include="Feature146PortableSceneCompatibilityTests.fs" />
    <Compile Include="Feature146PortableSceneResourceTests.fs" />
    <Compile Include="Feature146PackageCapabilityInspectionTests.fs" />
    <Compile Include="Feature146PackageResourceInspectionTests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Scene\Scene.fsproj" />
    <PackageReference Include="Expecto" />
    <PackageReference Include="FsCheck" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

</Project>
