<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="KeyboardInputTests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <!-- Scene + SkiaViewer host vocabulary and the rich input runtime under test. -->
    <ProjectReference Include="..\..\src\Scene\Scene.fsproj" />
    <ProjectReference Include="..\..\src\SkiaViewer\SkiaViewer.fsproj" />
    <ProjectReference Include="..\..\src\Input\Input.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

</Project>
