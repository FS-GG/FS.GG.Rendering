<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <PropertyGroup>
    <!-- 211 (FR-006): release-only lane; consumes packed FS.GG.UI.* at TEST RUNTIME and is restored in
         release.yml under ContinuousIntegrationBuild=true. Opt out of the lockfile so it is never locked
         (its FS.GG.UI.* preview pins churn every merge). Defensive RestoreLockedMode=false in case a
         lockfile is ever generated by accident. -->
    <RestorePackagesWithLockFile>false</RestorePackagesWithLockFile>
    <RestoreLockedMode>false</RestoreLockedMode>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="SurfaceAreaTests.fs" Condition="Exists('SurfaceAreaTests.fs')" />
    <Compile Include="PackageApiReferenceTests.fs" />
    <Compile Include="NameCollisionSafetyTests.fs" />
    <Compile Include="GeneratedConsumerValidationTests.fs" />
    <Compile Include="FsiTranscriptCoverageTests.fs" />
    <Compile Include="Feature146CompatibilityLedgerTests.fs" />
    <Compile Include="Feature147CompatibilityLedgerTests.fs" />
    <Compile Include="Feature150CompatibilityLedgerTests.fs" />
    <Compile Include="Feature151CompatibilityLedgerTests.fs" />
    <Compile Include="CompatibilityLedgerTests.fs" />
    <Compile Include="Feature163PackageFeedValidationTests.fs" />
    <Compile Include="Feature170RetainedInspectionSurfaceTests.fs" />
    <Compile Include="Feature170CompatibilityTests.fs" />
    <Compile Include="Feature151PackageValidationTests.fs" />
    <Compile Include="Feature128DesignSystemTemplateTests.fs" />
    <Compile Include="Feature204LifecycleTemplateTests.fs" />
    <Compile Include="Feature205TemplateSideEffectTests.fs" />
    <Compile Include="Feature207BomMembershipTests.fs" />
    <Compile Include="Feature207BomConsumerTests.fs" />
    <Compile Include="Feature209VersionCoherenceTests.fs" />
    <Compile Include="Feature217ProductNameTemplateTests.fs" />
    <Compile Include="Tests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Scene\Scene.fsproj" Condition="Exists('..\..\src\Scene\Scene.fsproj')" />
    <ProjectReference Include="..\..\src\Diagnostics\Diagnostics.fsproj" Condition="Exists('..\..\src\Diagnostics\Diagnostics.fsproj')" />
    <ProjectReference Include="..\..\src\SkiaViewer\SkiaViewer.fsproj" Condition="Exists('..\..\src\SkiaViewer\SkiaViewer.fsproj')" />
    <ProjectReference Include="..\..\src\Testing\Testing.fsproj" Condition="Exists('..\..\src\Testing\Testing.fsproj')" />
    <ProjectReference Include="..\..\src\Layout\Layout.fsproj" Condition="Exists('..\..\src\Layout\Layout.fsproj')" />
    <ProjectReference Include="..\..\src\Controls\Controls.fsproj" Condition="Exists('..\..\src\Controls\Controls.fsproj')" />
    <ProjectReference Include="..\TestSupport\TestSupport.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Expecto" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="YoloDev.Expecto.TestSdk" />
  </ItemGroup>

</Project>
